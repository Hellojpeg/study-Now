# Environment Configuration for Study-Now
# Copy this file to .env and fill in your values

# ======================
# CONVEX CONFIGURATION
# ======================
# Your Convex deployment URL (found in Convex dashboard)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Admin key for running Convex scripts (found in Convex dashboard > Settings)
CONVEX_ADMIN_KEY=your_admin_key_here

# ======================
# AI / API KEYS
# ======================
# Google Gemini API key for AI-powered question extraction
# Get one at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ======================
# TEACHER ACCOUNT SETUP
# ======================
# Used by scripts/create_teacher.js to create teacher accounts
# Set these in your environment when running the script
# TEACHER_EMAIL=teacher@school.edu
# TEACHER_PASSWORD=secure_password_here
# TEACHER_NAME=Teacher Name
