rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: STUDENT, TEACHER)
    //   - avatar: string (optional)
    //
    // Collection: scores
    // Document ID: {scoreId} (auto-generated)
    // Fields:
    //   - userId: string (required)
    //   - subjectId: string (required)
    //   - score: number (required)
    //   - totalQuestions: number (required)
    //   - timestamp: timestamp (required)
    //   - missedQuestions: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEACHER' ||
         (request.auth.token.email == "JPGomezMedia@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.role in ['STUDENT', 'TEACHER'];
    }

    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'subjectId', 'score', 'totalQuestions', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.score is number && data.totalQuestions is number &&
             data.subjectId is string;
    }

    // Rules
    match /users/{userId} {
      // Users can read their own profile, or teachers can read all students
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if the data matches the auth context
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'STUDENT' || isAdmin());
      
      // Allow update of name/avatar by owner, or role by admin
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /scores/{scoreId} {
      // Users read their own scores; teachers read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can only create scores for themselves
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      
      // Scores are immutable
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
