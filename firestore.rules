rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: STUDENT, TEACHER, ADMIN)
    //   - avatar: string (optional)
    //
    // Collection: scores
    // Document ID: {scoreId} (auto-generated)
    // Fields:
    //   - userId: string (required)
    //   - subjectId: string (required)
    //   - score: number (required)
    //   - totalQuestions: number (required)
    //   - timestamp: timestamp (required)
    //   - missedQuestions: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBootstrapAdminEmail() {
      return isAuthenticated() &&
        request.auth.token.email is string &&
        request.auth.token.email.matches("(?i)^jpgomezmedia@gmail\\.com$");
    }

    function roleForCurrentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeacherOrAdmin() {
      return isAuthenticated() &&
        (roleForCurrentUser() in ['TEACHER', 'ADMIN'] || isBootstrapAdminEmail());
    }

    function isAdmin() {
      return isAuthenticated() && 
        (roleForCurrentUser() == 'ADMIN' || isBootstrapAdminEmail());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.role in ['STUDENT', 'TEACHER', 'ADMIN'];
    }

    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'subjectId', 'score', 'totalQuestions', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.score is number && data.totalQuestions is number &&
             data.subjectId is string;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll([
        'userId',
        'subjectId',
        'score',
        'totalQuestions',
        'percentage',
        'studentFirstName',
        'studentLastName',
        'period',
        'confirmationCode',
        'timestamp'
      ]) &&
      data.userId == request.auth.uid &&
      data.score is number &&
      data.totalQuestions is number &&
      data.percentage is number &&
      data.subjectId is string &&
      data.studentFirstName is string && data.studentFirstName.size() > 0 && data.studentFirstName.size() <= 60 &&
      data.studentLastName is string && data.studentLastName.size() > 0 && data.studentLastName.size() <= 60 &&
      data.period is string && data.period.size() > 0 && data.period.size() <= 20 &&
      data.confirmationCode is string && data.confirmationCode.size() >= 8 && data.confirmationCode.size() <= 40;
    }

    // Rules
    match /users/{userId} {
      // Users can read their own profile, or teachers/admins can read all students
      allow read: if isOwner(userId) || isTeacherOrAdmin();
      
      // Allow creation if the data matches the auth context
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (
                        request.resource.data.role == 'STUDENT' ||
                        request.resource.data.role == 'TEACHER' ||
                        (request.resource.data.role == 'ADMIN' && isAdmin())
                      );
      
      // Allow update of name/avatar by owner, or role by admin
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /scores/{scoreId} {
      // Users read their own scores; teachers/admins read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isTeacherOrAdmin());
      
      // Users can only create scores for themselves
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      
      // Scores are immutable
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /quizSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isTeacherOrAdmin());
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /appSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && docId == 'gameVisibility';
    }
  }
}
