{
  "name": "midterm-prep-assistant",
  "version": "1.0.0",
  "description": "A rapid-fire study application for World History, Civics, and US History Midterms.",
  "type": "module",
  "main": "index.tsx",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "canvas-confetti": "^1.9.2",
    "convex": "^1.31.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.556.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.7"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "server": "node server.js",
    "check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "postinstall": "node scripts/fix_convex_tsconfig.cjs || true; if [ -f \"node_modules/.bin/vite\" ]; then npm run build; else echo \"vite not found, skipping build\"; fi"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
